{
  "version": 1,
  "disable_existing_loggers": true,
  "formatters": {
    "standard": {
      "format": "[%(asctime)s.%(msecs)03d | %(levelname)s | %(name)s:%(lineno)s] %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    }
  },
  "handlers": {
    "console_handler": {
      "level": "NOTSET",
      "formatter": "standard",
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stdout"
    },
    "file_handler": {
      "level": "NOTSET",
      "formatter": "standard",
      "class": "logging.FileHandler",
      "filename": "experiment.log",
      "mode": "a"
    }
  },
  "loggers": {
    "": {
      "handlers": [
        "console_handler"
      ],
      "level": "WARNING",
      "propagate": false
    },
    "pytorch_lightning": {
      "handlers": [
        "console_handler",
        "file_handler"
      ],
      "level": "INFO",
      "propagate": false
    },
    "ef": {
      "handlers": [
        "console_handler",
        "file_handler"
      ],
      "level": "INFO",
      "propagate": false
    },
    "cafa": {
      "handlers": [
        "console_handler",
        "file_handler"
      ],
      "level": "INFO",
      "propagate": false
    },
    "__main__": {
      "handlers": [
        "console_handler",
        "file_handler"
      ],
      "level": "INFO",
      "propagate": false
    }
  }
}
